{
  "name": "whatsbiz-workspace",
  "version": "1.0.0",
  "description": "WhatsBiz Workspace for Backend & Frontend",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "start:dev": "npm run start:dev --prefix backend",
    "backend": "npm run start:dev --prefix backend",
    "frontend": "npm run dev --prefix frontend"
  }
}
